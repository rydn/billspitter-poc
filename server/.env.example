# Copy this file to ".env" and fill in your key.
# The .env file is gitignored and is read only on the server.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional overrides
PORT=3001
GEMINI_MODEL=gemini-2.5-flash

# OCR provider selection:
#   auto   - try the local Ollama vision model first, fall back to Gemini (default)
#   local  - use the local Ollama vision model only
#   gemini - use Gemini only
BILL_OCR_PROVIDER=auto

# Local vision model via Ollama (https://ollama.com)
#   Install:  brew install --cask ollama-app   (the plain formula lacks the runner)
#   Pull:     ollama pull qwen3-vl:8b
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3-vl:8b
# OLLAMA_TIMEOUT_MS=120000
# Context window in tokens. Receipt images can exceed the 4096 default, so we
# use 16384. Lower it to save memory, or raise it for very large images.
# OLLAMA_NUM_CTX=16384
